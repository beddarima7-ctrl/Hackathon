{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true,
        "rootDir": ".",
        "outDir": "./dist",
        "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "managed/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}